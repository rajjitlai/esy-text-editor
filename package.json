{
  "name": "esy-text-editor",
  "version": "1.0.0",
  "private": true,
  "description": "Esy Text Editor is a minimal markdown workspace built with React, Tailwind CSS, and Electron.",
  "author": "Rajjit Laishram <20rajjit@gmail.com>",
  "main": "dist-electron/main.js",
  "scripts": {
    "generate:icons": "node scripts/generate-icons.mjs",
    "dev": "vite",
    "dev:desktop": "concurrently -k \"vite\" \"npm run dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.2",
    "@radix-ui/react-slot": "^1.2.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.538.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.0.12",
    "eslint": "^9.34.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.esytext.editor",
    "productName": "Esy Text Editor",
    "directories": {
      "buildResources": "buildResources",
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "mac": {
      "icon": "buildResources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "buildResources/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "buildResources/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
